APP_NAME="Sales Assistant"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, zero-config for local dev)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# MySQL (recommended for production on Hostinger)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=your_database
# DB_USERNAME=your_username
# DB_PASSWORD=your_password

# ── Sessions ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
# SESSION_SECURE_COOKIE=true   # enable in production (requires HTTPS)

# ── Cache / Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=sync          # no persistent workers needed (cPanel-friendly)

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # default; override to change model

# ── Upload limits ─────────────────────────────────────────────────────────────
UPLOAD_MAX_FILE_KB=10240           # max size per file in KB  (10 MB default)
UPLOAD_MAX_FILES_PER_CLIENT=50     # max number of reports per client account
